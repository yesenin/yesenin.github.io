@model WordViewModel
@{
    ViewData["Title"] = "Word";
    var wordKinds = new List<SelectListItem> {
        new SelectListItem {
            Text = "N/A",
            Value = null
        },
        new SelectListItem {
            Text = "Substantiv",
            Value = "substantiv"
        },
        new SelectListItem {
            Text = "Verb",
            Value = "verb"
        },
        new SelectListItem {
            Text = "Konjunktion",
            Value = "konjunktion"
        },
        new SelectListItem {
            Text = "Adverb",
            Value = "adverb"
        },
        new SelectListItem {
            Text = "Adjektiv",
            Value = "adjektiv"
        },
        new SelectListItem {
            Text = "Preposition",
            Value = "preposition"
        }
    };
}


<div class="row">
    @Html.ActionLink("List", "Index", "Home")
</div>

<div class="row">
    <div class="word_title">
        <h1>@Model.Value</h1>
    </div>

</div>


<div class="row">
    <h3>Kind</h3>

    <form asp-route="updateword" asp-route-id="@Model.Id"
        data-ajax="true" data-ajax-method="POST" >
        <div class="form-group">
            <input type="text" class="form-control" id="AjaxValidationModelAge" asp-for="Kind" placeholder="0">
            <span asp-validation-for="Kind" class="text-danger"></span>
        </div>
        <div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </div>
    </form>
</div>

<div class="row">
    <h3>Kind details</h3>
</div>

<div class="row">
    <h3>Translations</h3>
</div>

<div class="row">
    <h3>Relations</h3>
</div>

<div class="row">
    <h3>Exmaples</h3>
</div>

<div class="row">
    <h3>Statistics</h3>
</div>